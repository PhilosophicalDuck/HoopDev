# Copy this file to .env and fill in your values
DATABASE_URL=sqlite:///./basketball_app.db
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CAMERA_INDEX=0
DETECTION_MODEL_PATH=models/best_yolox_player_detection.pt
POSE_MODEL_NAME=yolo11n-pose.pt
HIGHLIGHTS_DIR=highlights
ROBOFLOW_API_KEY=your_key_here

# AI Coach chat
MOCK_CHAT=false
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434
